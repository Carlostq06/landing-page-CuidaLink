---
import { Image } from "astro:assets";
import logo from "../../assets/CuidaLink.svg"

// src/components/Navbar.astro
const pathname = new URL(Astro.url).pathname;
const currentPath = pathname.slice(1); // Quita la barra inclinada "/" inicial

// Definimos los enlaces para no repetir código
const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Sobre Nosotros', href: '/about' },
  { name: 'Ayuda', href: '/ayuda' },
  { name: 'Contacto', href: '/contacto' },
];
---

<header class="fixed left-0 right-0 top-0 z-50 flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 bg-white/90 px-6 py-3 shadow-sm backdrop-blur-md md:px-10">
  <div class="flex items-center gap-4">
  <a href="/" class="block">
    <Image
      alt="Logo de CuidaLink"
      class="h-8 w-auto"
      src={logo}
      loading="eager"
    />
  </a>
</div>

  <div class="hidden flex-1 justify-end gap-8 md:flex">
    <div class="flex items-center gap-9">
      {
        navItems.slice(1).map((item) => (
          <a
            class={`nav-link text-sm font-medium transition-colors hover:text-primary ${currentPath === item.href.slice(1) ? 'text-primary' : 'text-slate-600'}`}
            href={item.href}
          >
            {item.name}
          </a>
        ))
      }
    </div>
    <button class="btn-shine soft-glow flex h-10 cursor-pointer items-center justify-center overflow-hidden rounded-xl bg-primary px-6 text-sm font-bold text-white shadow-md transition-all hover:bg-primary-hover">
      <span class="truncate">Acceder</span>
    </button>
  </div>

  <details class="group relative md:hidden">
    <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg text-slate-900 transition-colors hover:bg-slate-100 [&::-webkit-details-marker]:hidden">
      <span class="material-symbols-outlined">menu</span>
      <span class="sr-only">Abrir o cerrar menu de navegacion</span>
    </summary>

    <nav class="pointer-events-none absolute right-0 top-14 w-[min(86vw,20rem)] scale-[0.98] rounded-2xl border border-slate-200 bg-white/95 p-4 opacity-0 shadow-xl backdrop-blur-md transition duration-200 -translate-y-2 group-open:pointer-events-auto group-open:translate-y-0 group-open:scale-100 group-open:opacity-100">
      <ul class="flex flex-col gap-2">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class={`block rounded-xl px-4 py-3 text-sm font-medium transition-colors ${currentPath === item.href.slice(1) ? 'bg-primary-light text-primary' : 'text-slate-700 hover:bg-slate-100'}`}
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>

      <button class="btn-shine soft-glow mt-4 flex h-11 w-full cursor-pointer items-center justify-center overflow-hidden rounded-xl bg-primary px-6 text-sm font-bold text-white shadow-md transition-all hover:bg-primary-hover">
        <span class="truncate">Acceder</span>
      </button>
    </nav>
  </details>
</header>
