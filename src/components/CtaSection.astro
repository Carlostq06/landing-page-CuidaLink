---
import { Image } from "astro:assets";

import doctorImage  from "../assets/doctor.png";
---

<section class="reveal bg-background-light px-4 py-16 md:px-10">
  <div class="card-glint reveal mx-auto max-w-[1200px] overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-slate-100">
    <div class="flex flex-col md:flex-row">
      <div class="relative flex flex-1 flex-col justify-center overflow-hidden p-10 md:p-16">
        <div class="absolute inset-0 z-0 bg-gradient-to-br from-primary to-green-700"></div>
        <div class="relative z-10 text-white">
          <h2 class="mb-4 text-3xl font-bold md:text-4xl">Listo para empezar?</h2>
          <p class="mb-8 text-lg text-green-50">
            Unete a nuestra comunidad hoy mismo y descubre la tranquilidad de tener el mejor cuidado.
          </p>
          <div class="reveal delay-2 flex flex-wrap gap-4">
            <button class="btn-shine hover-lift rounded-xl bg-white px-6 py-3 font-bold text-primary shadow-sm transition-colors hover:bg-green-50">
              Crear cuenta gratis
            </button>
          </div>
        </div>
      </div>

      <div class="reveal reveal-right delay-2 relative min-h-[300px] flex-1 bg-green-100 md:min-h-0">
        <div class="absolute inset-0 z-10 bg-gradient-to-r from-primary/90 to-transparent md:bg-gradient-to-t md:from-primary/90 md:to-transparent"></div>
        <Image
          alt="Doctor sonriendo con una tablet"
          class="h-full w-full object-cover opacity-80 mix-blend-multiply transition-transform duration-700 hover:scale-105"
          src={doctorImage}
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
