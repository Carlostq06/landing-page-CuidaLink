---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/index/SiteHeader.astro";
import SiteFooter from "../components/index/SiteFooter.astro";
---

<Layout title="Contacto - CuidaLink">
  <div class="relative w-full overflow-x-hidden">
    <SiteHeader />
    <main class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
      <header class="mb-16">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 mb-4">
          Estamos aquí para ayudarte.
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl leading-relaxed">
          Tanto si eres un profesional de la salud como si buscas el mejor cuidado para los tuyos, nuestro equipo de CuidaLink está listo para responder tus dudas.
        </p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <section class="lg:col-span-7 bg-white p-8 md:p-12 rounded-2xl border border-slate-200 shadow-sm">
          <form class="space-y-8" action="https://formsubmit.co/cuidalink92@gmail.com" method="POST">
            <input type="hidden" name="_subject" value="Nuevo mensaje de contacto - CuidaLink" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="block text-sm font-bold tracking-wide uppercase text-slate-700" for="name">Nombre</label>
                <input class="w-full bg-slate-50 border border-slate-200 rounded-xl p-4 text-slate-900 placeholder-slate-400 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" id="name" name="name" placeholder="Tu nombre completo" type="text" required />
              </div>
              <div class="space-y-2">
                <label class="block text-sm font-bold tracking-wide uppercase text-slate-700" for="email">Correo Electrónico</label>
                <input class="w-full bg-slate-50 border border-slate-200 rounded-xl p-4 text-slate-900 placeholder-slate-400 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none" id="email" name="email" placeholder="ejemplo@correo.com" type="email" required />
              </div>
            </div>
            <div class="space-y-2">
              <label class="block text-sm font-bold tracking-wide uppercase text-slate-700" for="message">Mensaje</label>
              <textarea class="w-full bg-slate-50 border border-slate-200 rounded-xl p-4 text-slate-900 placeholder-slate-400 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none resize-none" id="message" name="message" placeholder="¿En qué podemos ayudarte?" rows="6" required></textarea>
            </div>
            <button class="w-full md:w-auto bg-primary hover:bg-primary/90 text-white px-10 py-4 rounded-xl font-bold text-lg transition-all shadow-lg shadow-primary/20" type="submit">Enviar Mensaje</button>
          </form>
        </section>

        <aside class="lg:col-span-5 space-y-12">
          <div class="space-y-6">
            <div class="flex items-start gap-6 p-6 rounded-2xl bg-slate-50 border border-slate-200">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-primary">mail</span>
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900">Escríbenos</h3>
                <p class="text-sm text-slate-600 mt-1">Nuestro equipo responde en menos de 24h.</p>
                <a class="text-primary font-semibold mt-2 block hover:underline" href="mailto:cuidalink92@gmail.com">cuidalink92@gmail.com</a>
              </div>
            </div>
            <div class="flex items-start gap-6 p-6 rounded-2xl bg-slate-50 border border-slate-200">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-primary">call</span>
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900">Llámanos</h3>
                <p class="text-sm text-slate-600 mt-1">Lunes a Viernes, de 9:00 a 18:00.</p>
                <p class="text-primary font-semibold mt-2 block">+34 643 530 388</p>
              </div>
            </div>
          </div>

          <div class="p-8 bg-slate-900 rounded-2xl text-white">
            <h3 class="text-sm font-bold tracking-widest uppercase mb-6 text-slate-300">Síguenos en redes</h3>
            <div class="flex gap-4">
              <a class="w-12 h-12 rounded-full bg-slate-700 hover:bg-primary transition-colors flex items-center justify-center" href="#"><span class="material-symbols-outlined text-2xl">public</span></a>
              <a class="w-12 h-12 rounded-full bg-slate-700 hover:bg-primary transition-colors flex items-center justify-center" href="#"><span class="material-symbols-outlined text-2xl">share</span></a>
              <a class="w-12 h-12 rounded-full bg-slate-700 hover:bg-primary transition-colors flex items-center justify-center" href="#"><span class="material-symbols-outlined text-2xl">groups</span></a>
            </div>
          </div>

          <div class="bg-primary/5 p-6 rounded-2xl relative overflow-hidden border border-primary/20">
            <div class="relative z-10 flex items-center gap-3">
              <div class="status-pulse"></div>
              <span class="text-sm font-bold uppercase tracking-wider text-primary">Oficina Central Activa</span>
            </div>
            <p class="relative z-10 mt-2 text-slate-700 text-sm">Madrid, España. Soporte global disponible.</p>
            <div class="absolute -right-10 -bottom-10 opacity-5"><span class="material-symbols-outlined text-9xl">location_on</span></div>
          </div>
        </aside>
      </div>
    </main>
    <SiteFooter />
  </div>
</Layout>

<style>
  .status-pulse {
    width: 8px;
    height: 8px;
    background: radial-gradient(circle, #006a45 0%, rgba(0, 106, 69, 0) 70%);
    border-radius: 50%;
  }
</style>
