---
import AdvancedFeaturesSection from '../components/AdvancedFeaturesSection.astro';
import CtaSection from '../components/CtaSection.astro';
import FaqSection from '../components/FaqSection.astro';
import HeroSection from '../components/HeroSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import WhyChooseSection from '../components/WhyChooseSection.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bienvenida a CuidaLink">
	<div class="relative w-full overflow-x-hidden">
		<SiteHeader />

		<main class="flex flex-col pt-14">
			<HeroSection />
			<WhyChooseSection />
			<HowItWorksSection />
			<AdvancedFeaturesSection />
			<FaqSection />
			<CtaSection />
		</main>

		<SiteFooter />
	</div>
</Layout>
